<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">

    <SwitchPreferenceCompat
        android:key="pref_incident_management_enabled"
        android:title="@string/pref_title_incident_management_enabled"
        android:summary="@string/pref_summary_incident_management_enabled"
        android:defaultValue="true" />

    <PreferenceCategory
        android:title="@string/pref_header_incident_providers">

        <EditTextPreference
            android:key="pagerduty_api_token"
            android:title="@string/pref_title_pagerduty_api_token"
            android:summary="@string/pref_summary_pagerduty_api_token"
            android:inputType="textPassword" />

        <EditTextPreference
            android:key="pagerduty_user_email"
            android:title="@string/pref_title_pagerduty_user_email"
            android:summary="@string/pref_summary_pagerduty_user_email"
            android:inputType="textEmailAddress" />

        <Preference
            android:key="test_pagerduty_connection"
            android:title="@string/pref_title_test_pagerduty_connection"
            android:summary="@string/pref_summary_test_pagerduty_connection" />

        <EditTextPreference
            android:key="opsgenie_api_key"
            android:title="@string/pref_title_opsgenie_api_key"
            android:summary="@string/pref_summary_opsgenie_api_key"
            android:inputType="textPassword" />

        <Preference
            android:key="test_opsgenie_connection"
            android:title="@string/pref_title_test_opsgenie_connection"
            android:summary="@string/pref_summary_test_opsgenie_connection" />

        <EditTextPreference
            android:key="rootly_api_token"
            android:title="@string/pref_title_rootly_api_token"
            android:summary="@string/pref_summary_rootly_api_token"
            android:inputType="textPassword" />

        <Preference
            android:key="test_rootly_connection"
            android:title="@string/pref_title_test_rootly_connection"
            android:summary="@string/pref_summary_test_rootly_connection" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/pref_header_incident_filtering">

        <MultiSelectListPreference
            android:key="incident_app_whitelist"
            android:title="@string/pref_title_incident_app_whitelist"
            android:summary="@string/pref_summary_incident_app_whitelist"
            android:entries="@array/incident_apps"
            android:entryValues="@array/incident_app_values"
            android:defaultValue="@array/incident_app_values" />

        <EditTextPreference
            android:key="incident_content_filter"
            android:title="@string/pref_title_incident_content_filter"
            android:summary="@string/pref_summary_incident_content_filter"
            android:defaultValue="P1,P2,CRITICAL,HIGH" />

        <EditTextPreference
            android:key="custom_severity_regex"
            android:title="@string/pref_title_custom_regex"
            android:summary="@string/pref_summary_custom_regex"
            android:defaultValue="" />

        <ListPreference
            android:key="default_severity"
            android:title="@string/pref_title_default_severity"
            android:summary="@string/pref_summary_default_severity"
            android:entries="@array/severity_levels"
            android:entryValues="@array/severity_values"
            android:defaultValue="P3" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/pref_header_oncall_schedule">

        <SwitchPreferenceCompat
            android:key="oncall_schedule_enabled"
            android:title="@string/pref_title_oncall_schedule"
            android:summary="@string/pref_summary_oncall_schedule"
            android:defaultValue="false" />

        <EditTextPreference
            android:key="oncall_start_time"
            android:title="@string/pref_title_oncall_start"
            android:defaultValue="09:00"
            android:inputType="time" />

        <EditTextPreference
            android:key="oncall_end_time"
            android:title="@string/pref_title_oncall_end"
            android:defaultValue="18:00"
            android:inputType="time" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/pref_header_webhook">

        <SwitchPreferenceCompat
            android:key="webhook_enabled"
            android:title="@string/pref_title_webhook_enabled"
            android:summary="@string/pref_summary_webhook_enabled"
            android:defaultValue="false" />

        <EditTextPreference
            android:key="webhook_url"
            android:title="@string/pref_title_webhook_url"
            android:summary="@string/pref_summary_webhook_url"
            android:inputType="textUri" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/pref_header_contact_filter">

        <EditTextPreference
            android:key="escalation_contacts"
            android:title="@string/pref_title_escalation_contacts"
            android:summary="@string/pref_summary_escalation_contacts"
            android:defaultValue="" />

    </PreferenceCategory>

</PreferenceScreen>
